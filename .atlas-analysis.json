  "keyFeatures": [
    "Multi-version dev tool management (Node, Python, Go, Ruby, and hundreds more)",
    "Automatic environment variable management per project directory",
    "Built-in task runner with parallel execution and file watching",
    "Hierarchical configuration with mise.toml files",
    "Multiple backends: asdf, aqua, cargo, npm, GitHub releases, and more",
    "Shell activation for seamless auto-switching between tool versions",
    "Secrets management with support for external providers",
    "ASDF compatibility and plugin ecosystem support"
  ],
  "publicApiSurface": [
    "mise use <tool>@<version>",
    "mise install [tool@version]",
    "mise exec <tool@version> -- <command>",
    "mise run <task>",
    "mise env [--json] [--dotenv]",
    "mise ls [--current]",
    "mise activate <shell>",
    "mise set <KEY>=<value>",
    "mise plugins install <name> [url]",
    "mise upgrade [tool]",
    "mise doctor",
    "mise.toml [tools] section",
    "mise.toml [env] section",
    "mise.toml [tasks] section"
  ]
